{
  "basic_config": {
    "description": "基础配置",
    "items": {
      "connection_mode": {
        "default": "server",
        "description": "连接模式",
        "hint": "server=无界面 HTTP API；web=浏览器 WebUI；tui=终端界面",
        "options": ["server", "web", "tui"],
        "type": "string"
      },
      "only_admin": {
        "default": true,
        "description": "仅限管理员使用",
        "type": "bool"
      },
      "password": {
        "default": "",
        "description": "Basic Auth 密码",
        "hint": "对应 OPENCODE_SERVER_PASSWORD 环境变量",
        "obvious_hint": true,
        "type": "string"
      },
      "server_url": {
        "default": "http://127.0.0.1:4096",
        "description": "OpenCode Server URL",
        "type": "string"
      },
      "timeout": {
        "default": 300,
        "description": "请求超时(秒)",
        "type": "int"
      },
      "username": {
        "default": "opencode",
        "description": "Basic Auth 用户名",
        "type": "string"
      }
    },
    "type": "object"
  },
  "model_config": {
    "description": "模型配置",
    "items": {
      "default_model": {
        "default": "",
        "description": "默认模型 provider/model",
        "type": "string"
      },
      "default_variant": {
        "default": "",
        "description": "默认思考等级/模型变体",
        "options": ["", "none", "minimal", "low", "medium", "high", "xhigh", "max"],
        "type": "string"
      },
      "show_thinking": {
        "default": false,
        "description": "推送思考内容",
        "hint": "保留配置项；当前推送级别控制是否推送思考中提示，不推送推理正文",
        "type": "bool"
      }
    },
    "type": "object"
  },
  "notification_config": {
    "description": "通知配置",
    "items": {
      "max_reconnect_attempts": {
        "default": 10,
        "description": "SSE 最大重连次数",
        "hint": "0 表示无限重连",
        "type": "int"
      },
      "reconnect_backoff_base": {
        "default": 2,
        "description": "SSE 重连退避基数(秒)",
        "hint": "第 N 次重连等待 min(60, base^N) 秒",
        "type": "int"
      },
      "output_level": {
        "default": "simple",
        "description": "SSE 推送级别",
        "hint": "silence=权限/提问/错误/完成；simple=思考中+最终文本；summary=完成摘要；detail=工具过程+最终文本",
        "options": ["silence", "simple", "summary", "detail"],
        "type": "string"
      },
      "quick_prefix": {
        "default": ">",
        "description": "快捷发送前缀",
        "hint": "如 '> 任务内容' 发送到当前会话，'>2 任务内容' 发送到第2个会话",
        "type": "string"
      },
      "summary_msg_count": {
        "default": 5,
        "description": "summary 推送消息条数",
        "type": "int"
      },
      "auto_summary": {
        "default": false,
        "description": "任务完成后自动推送变更摘要",
        "hint": "开启后，session.idle 事件触发时会抓取 Git diff 并推送变更统计",
        "type": "bool"
      }
    },
    "type": "object"
  },
  "security_config": {
    "description": "安全配置",
    "items": {
      "confirm_delete": {
        "default": true,
        "description": "删除会话前确认",
        "type": "bool"
      },
      "confirm_shell": {
        "default": true,
        "description": "执行 shell 前确认",
        "type": "bool"
      },
      "confirm_timeout": {
        "default": 30,
        "description": "确认超时(秒)",
        "type": "int"
      },
      "destructive_keywords": {
        "default": ["删除", "格式化", "清空", "rm\\b", "delete\\b", "format\\b", "wipe\\b", "destroy\\b", "shutdown\\b", "reboot\\b", "mkfs", "dd\\b", "> /dev/"],
        "description": "敏感关键词(正则)",
        "type": "list"
      }
    },
    "type": "object"
  },
  "tool_config": {
    "description": "LLM 工具配置",
    "items": {
      "enable_llm_tools": {
        "default": false,
        "description": "启用自然语言工具",
        "hint": "启用后提供会话查询、发送、切换、模型查询、目录切换等 OpenCode LLM 工具",
        "type": "bool"
      }
    },
    "type": "object"
  },
  "router_config": {
    "description": "聊天-工作路由配置",
    "items": {
      "enable_auto_route": {
        "default": false,
        "description": "启用自动路由",
        "hint": "开启后，疑似代码任务的普通消息会被路由到 OpenCode。建议先测试确认模式。",
        "type": "bool"
      },
      "mode": {
        "default": "confirm",
        "description": "路由模式",
        "hint": "off=关闭自动路由；confirm=疑似任务先询问确认；auto=高置信度任务直接执行",
        "options": ["off", "confirm", "auto"],
        "type": "string"
      },
      "work_prefixes": {
        "default": ["/work", "/code"],
        "description": "显式工作前缀列表",
        "hint": "消息以此开头时，直接作为 OpenCode 任务执行，不经过评分判断",
        "type": "list"
      },
      "confirm_threshold": {
        "default": 0.65,
        "description": "确认阈值",
        "hint": "任务评分超过此值时进入确认流程（询问用户是否执行）",
        "type": "float"
      },
      "auto_threshold": {
        "default": 0.85,
        "description": "自动执行阈值",
        "hint": "任务评分超过此值且模式为 auto 时，直接执行不询问",
        "type": "float"
      },
      "confirm_timeout": {
        "default": 60,
        "description": "路由确认超时(秒)",
        "hint": "等待用户确认/取消的超时时间",
        "type": "int"
      },
      "ignore_group_messages_without_mention": {
        "default": true,
        "description": "群聊中忽略未 @ 的消息",
        "hint": "开启后，群聊中的普通消息除非 @ Bot 或被显式前缀触发，否则不走自动路由",
        "type": "bool"
      },
      "intent_model": {
        "default": "",
        "description": "意图分类模型",
        "hint": "用于 LLM 意图分类的模型 provider/model，留空则使用当前会话模型。建议用轻量模型如 openai/gpt-4o-mini",
        "type": "string"
      },
      "enable_llm_intent": {
        "default": false,
        "description": "启用 LLM 意图分类",
        "hint": "开启后，当规则评分在 confirm_threshold 和 auto_threshold 之间时，调用 LLM 做二次判断",
        "type": "bool"
      },
      "work_keywords": {
        "default": [
          "修复", "bug", "改错", "报错", "error", "failed", "失败",
          "代码", "code", "coding", "编程", "开发", "dev",
          "实现", "添加功能", "补", "重构", "refactor",
          "优化", "性能", "慢", "卡", "崩溃", "crash",
          "CI", "构建", "build", "测试", "test",
          "部署", "deploy", "跑不通", "跑不起来"
        ],
        "description": "工作任务关键词列表",
        "hint": "命中关键词会增加任务评分",
        "type": "list"
      }
    },
    "type": "object"
  },
  "project_aliases": {
    "description": "项目别名配置",
    "items": {},
    "hint": "键为别名，值为路径。示例: {\"api\": \"/projects/api-service\"}",
    "type": "object"
  },
  "workspace_config": {
    "description": "工作路径配置",
    "items": {
      "allowed_workdirs": {
        "default": [],
        "description": "允许切换的工作路径白名单",
        "type": "list"
      },
      "check_path_safety": {
        "default": true,
        "description": "启用路径安全检查",
        "hint": "开启后，只能访问白名单或默认路径下的目录",
        "type": "bool"
      },
      "default_workdir": {
        "default": "",
        "description": "默认工作路径",
        "type": "string"
      }
    },
    "type": "object"
  }
}
